@page "/register"

<PageTitle>Register | Ageless Living™</PageTitle>

<section class="min-h-[80vh] flex items-center justify-center py-12 px-6">
    <div class="w-full max-w-[400px]">
        <div class="text-center mb-8">
            <a href="/" class="font-display text-[26px] font-medium text-brand-teal-dark">Ageless Living™</a>
            <p class="text-[13px] text-brand-muted mt-2">Create your account</p>
        </div>

        <div class="bg-white rounded-2xl border border-brand-border p-8">
            <form class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[13px] font-medium mb-1.5">First name</label>
                        <input
                            type="text"
                            placeholder="Jane"
                            class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition" />
                    </div>
                    <div>
                        <label class="block text-[13px] font-medium mb-1.5">Last name</label>
                        <input
                            type="text"
                            placeholder="Doe"
                            class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition" />
                    </div>
                </div>

                <div>
                    <label class="block text-[13px] font-medium mb-1.5">Email</label>
                    <input
                        type="email"
                        placeholder="you@example.com"
                        class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition" />
                </div>

                <div>
                    <label class="block text-[13px] font-medium mb-1.5">Phone</label>
                    <input
                        type="tel"
                        placeholder="+1 (604) 555-0123"
                        class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition" />
                </div>

                <div>
                    <label class="block text-[13px] font-medium mb-1.5">Password</label>
                    <input
                        type="password"
                        placeholder="••••••••"
                        class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition" />
                </div>

                <div>
                    <label class="block text-[13px] font-medium mb-1.5">Preferred location</label>
                    <select class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition text-brand-muted">
                        <option value="">Select location</option>
                        <option value="langley">Langley</option>
                        <option value="victoria">Victoria</option>
                        <option value="kelowna">Kelowna</option>
                    </select>
                </div>

                <label class="flex items-start gap-2 cursor-pointer">
                    <input type="checkbox" class="rounded border-brand-border mt-1" />
                    <span class="text-[13px] text-brand-muted">
                        I agree to receive wellness tips and promotional emails from Ageless Living.
                    </span>
                </label>

                <button type="submit" class="w-full bg-brand-teal text-white py-3.5 rounded-lg text-[14px] font-medium hover:bg-brand-teal-dark transition">
                    Create account
                </button>
            </form>

            <div class="mt-6 text-center">
                <p class="text-[13px] text-brand-muted">
                    Already have an account?
                    <a href="/login" class="text-brand-teal font-medium hover:underline">Sign in</a>
                </p>
            </div>
        </div>

        <p class="text-center text-[12px] text-brand-light-muted mt-6">
            Registration will be implemented in Phase 5.
        </p>
    </div>
</section>
