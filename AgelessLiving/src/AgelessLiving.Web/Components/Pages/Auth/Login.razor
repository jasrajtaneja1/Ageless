@page "/login"

<PageTitle>Login | Ageless Living™</PageTitle>

<section class="min-h-[80vh] flex items-center justify-center py-12 px-6">
    <div class="w-full max-w-[400px]">
        <div class="text-center mb-8">
            <a href="/" class="font-display text-[26px] font-medium text-brand-teal-dark">Ageless Living™</a>
            <p class="text-[13px] text-brand-muted mt-2">Sign in to your account</p>
        </div>

        <div class="bg-white rounded-2xl border border-brand-border p-8">
            <form class="space-y-4">
                <div>
                    <label class="block text-[13px] font-medium mb-1.5">Email</label>
                    <input
                        type="email"
                        placeholder="you@example.com"
                        class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition" />
                </div>

                <div>
                    <label class="block text-[13px] font-medium mb-1.5">Password</label>
                    <input
                        type="password"
                        placeholder="••••••••"
                        class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition" />
                </div>

                <div class="flex justify-between items-center text-[13px]">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" class="rounded border-brand-border" />
                        <span class="text-brand-muted">Remember me</span>
                    </label>
                    <a href="#" class="text-brand-teal hover:underline">Forgot password?</a>
                </div>

                <button type="submit" class="w-full bg-brand-teal text-white py-3.5 rounded-lg text-[14px] font-medium hover:bg-brand-teal-dark transition">
                    Sign in
                </button>
            </form>

            <div class="mt-6 text-center">
                <p class="text-[13px] text-brand-muted">
                    Don't have an account?
                    <a href="/register" class="text-brand-teal font-medium hover:underline">Sign up</a>
                </p>
            </div>
        </div>

        <p class="text-center text-[12px] text-brand-light-muted mt-6">
            Authentication will be implemented in Phase 5.
        </p>
    </div>
</section>
