            Tag="Our locations"
            Heading="Three clinics across British Columbia."
            Description="Visit us in Langley, Victoria, or Kelowna. Each location offers our full range of services with expert staff." />

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Langley -->
            <LocationCard City="Langley" Address="415-20178 96th Ave, Langley, BC V1M 0B2" Phone="+1 (236) 326-6830" Email="langley@agelessliving.ca">
                <HoursContent>
                    <div class="flex justify-between text-[12px] py-0.5">
                        <span class="font-medium text-brand-dark">Mon–Fri</span>
                        <span class="text-brand-muted">9:00 AM – 5:00 PM</span>
                    </div>
                    <div class="flex justify-between text-[12px] py-0.5">
                        <span class="font-medium text-brand-dark">Saturday</span>
                        <span class="text-brand-muted">10:00 AM – 4:00 PM</span>
                    </div>
                    <div class="flex justify-between text-[12px] py-0.5">
                        <span class="font-medium text-brand-dark">Sunday</span>
                        <span class="text-brand-muted">Closed</span>
                    </div>
                </HoursContent>
            </LocationCard>

            <!-- Victoria -->
            <LocationCard City="Victoria" Address="1-101 Burnside Rd W, Victoria, BC V9A 1B7" Phone="+1 (250) 590-5787" Email="wellness@agelessliving.ca">
