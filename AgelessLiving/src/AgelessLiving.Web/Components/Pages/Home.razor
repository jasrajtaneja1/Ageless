                        <span class="text-brand-muted">10:00 AM – 3:00 PM</span>
                    </div>
                    <div class="flex justify-between text-[12px] py-0.5">
                        <span class="font-medium text-brand-dark">Sunday</span>
                        <span class="text-brand-muted">Closed</span>
                    </div>
                </HoursContent>
            </LocationCard>

            <!-- Kelowna -->
            <LocationCard City="Kelowna" Address="102-3320 Richter St, Kelowna, BC V1W 4V5" Phone="+1 (778) 760-9827" Email="kelowna@agelessliving.ca">
