    <div>
        <span class="font-display text-[48px] font-light text-white">1</span>
        <p class="text-[13px] text-white/60">Choose your clinic</p>
        <div class="w-full h-px bg-white/[.12] my-4"></div>
        <p class="text-[13px] text-white/80 leading-[1.6] mb-4">Select from our three British Columbia locations.</p>
        <div class="flex flex-wrap gap-2">
            <button class="bg-white/10 text-white border border-white/20 rounded-full px-4 py-1.5 text-[12px] hover:bg-white/20 transition">
                Langley
            </button>
            <button class="bg-white/10 text-white border border-white/20 rounded-full px-4 py-1.5 text-[12px] hover:bg-white/20 transition">
