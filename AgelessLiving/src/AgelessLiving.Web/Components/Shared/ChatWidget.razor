@*
    ChatWidget: AI chatbot bubble that expands into a chat panel.
    Uses InteractiveServer for real-time message state.
    Currently uses keyword-based responses (will be replaced with ONNX in Phase 6).
*@

@rendermode InteractiveServer

<div class="fixed bottom-6 right-6 z-[200]">
    @if (!isOpen)
    {
        <!-- Collapsed Bubble -->
        <button @onclick="Toggle" class="w-[60px] h-[60px] rounded-full bg-brand-teal text-white shadow-[0_4px_20px_rgba(42,157,143,.3)] cursor-pointer hover:bg-brand-teal-dark hover:scale-105 transition flex items-center justify-center relative" aria-label="Open chat">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
            <span class="absolute -top-0.5 -right-0.5 w-3.5 h-3.5 rounded-full bg-brand-gold border-2 border-white"></span>
        </button>
    }
    else
    {
        <!-- Expanded Panel -->
        <div class="w-[380px] max-h-[min(580px,calc(100vh-100px))] bg-white rounded-2xl border border-brand-border shadow-[0_8px_40px_rgba(0,0,0,.12)] flex flex-col overflow-hidden">
            <!-- Header -->
            <div class="px-4 py-3.5 bg-brand-teal flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-white/20 flex items-center justify-center text-white text-[14px] font-medium">AI</div>
                    <div>
                        <p class="text-white text-[14px] font-medium">Ageless AI</p>
                        <p class="text-white/65 text-[11px]">Your wellness concierge</p>
                    </div>
                </div>
                <button @onclick="Toggle" class="text-white/80 hover:text-white text-[24px] leading-none" aria-label="Close chat">×</button>
            </div>

            <!-- Messages -->
            <div class="flex-1 overflow-y-auto p-4 flex flex-col gap-2.5 bg-brand-cream/50">
                @foreach (var message in _messages)
                {
                    <div class="@(message.IsBot ? "bg-brand-cream rounded-[2px_12px_12px_12px] self-start" : "bg-brand-teal text-white rounded-[12px_2px_12px_12px] self-end") px-3.5 py-2.5 text-[13px] max-w-[85%]">
                        @if (message.IsBot)
                        {
                            @((MarkupString)message.Text)
                        }
                        else
                        {
                            @message.Text
                        }
                    </div>
                }

                @if (_showQuickActions)
                {
                    <div class="flex flex-wrap gap-2 mt-2">
                        @foreach (var action in QuickActions)
                        {
                            <button @onclick="() => HandleQuickAction(action.Key)" class="bg-white border border-brand-border rounded-full px-3 py-1.5 text-[12px] text-brand-teal-dark hover:border-brand-teal hover:bg-brand-teal-light transition">
                                @action.Label
                            </button>
                        }
                    </div>
                }
            </div>

            <!-- Input -->
            <div class="px-3.5 py-2.5 border-t border-brand-border flex gap-2 items-center bg-white">
                <input @bind="_userInput" @bind:event="oninput" @onkeypress="HandleKeyPress" type="text" placeholder="Type your message..." class="flex-1 border border-brand-border rounded-full px-4 py-2.5 text-[13px] bg-brand-cream focus:border-brand-teal outline-none" />
                <button @onclick="SendMessage" class="w-[34px] h-[34px] rounded-full bg-brand-teal text-white flex items-center justify-center hover:bg-brand-teal-dark transition" aria-label="Send message">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
        </div>
    }
</div>

@code {
    private bool isOpen;
    private string _userInput = "";
    private bool _showQuickActions = true;
    private readonly List<ChatMessage> _messages = new();

    // Quick action buttons shown on chat open
    private static readonly (string Key, string Label)[] QuickActions =
    {
        ("recommend", "Recommend a treatment"),
        ("book", "Book a consultation"),
        ("pricing", "See pricing"),
        ("location", "Find a location")
    };

    // Quick action responses (user display text, bot response)
    private static readonly Dictionary<string, (string UserText, string BotResponse)> QuickActionResponses = new()
    {
        ["recommend"] = ("Recommend a treatment", "Based on our most popular treatments, I'd recommend:<br><br>• <strong>Botox/Dysport</strong> — From $299 CAD<br>• <strong>HydraFacial</strong> — From $199 CAD<br>• <strong>Bioidentical Hormone Therapy</strong> — Free consult<br><br>Would you like more details on any of these?"),
        ["book"] = ("Book a consultation", "Great! Which location works best for you?<br><br>• <strong>Langley</strong> — +1 (236) 326-6830<br>• <strong>Victoria</strong> — +1 (250) 590-5787<br>• <strong>Kelowna</strong> — +1 (778) 760-9827<br><br>You can also <a href='#booking' class='text-brand-teal underline'>book online</a>."),
        ["pricing"] = ("See pricing", "<strong>Skin Rejuvenation</strong><br>• Botox: From $299 CAD<br>• Fillers: From $449 CAD<br>• HydraFacial: From $199 CAD<br><br><strong>Hormone Therapy</strong><br>• Free initial consultation<br><br><strong>Biohacking</strong><br>• From $49–$199 CAD<br><br><strong>Healthy Weight</strong><br>• Free initial consultation"),
        ["location"] = ("Find a location", "<strong>Langley</strong><br>415-20178 96th Ave, Langley BC<br>+1 (236) 326-6830<br><br><strong>Victoria</strong><br>1-101 Burnside Rd W, Victoria BC<br>+1 (250) 590-5787<br><br><strong>Kelowna</strong><br>102-3320 Richter St, Kelowna BC<br>+1 (778) 760-9827")
    };

    protected override void OnInitialized()
    {
        _messages.Add(new ChatMessage(true, "👋 Hi! I'm your Ageless Living wellness concierge. How can I help you today?"));
    }

    private void Toggle() => isOpen = !isOpen;

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") SendMessage();
    }

    private void SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_userInput)) return;

        _showQuickActions = false;
        _messages.Add(new ChatMessage(false, _userInput));
        _messages.Add(new ChatMessage(true, GetBotResponse(_userInput.ToLower())));
        _userInput = "";
    }

    private void HandleQuickAction(string action)
    {
        _showQuickActions = false;
        if (QuickActionResponses.TryGetValue(action, out var response))
        {
            _messages.Add(new ChatMessage(false, response.UserText));
            _messages.Add(new ChatMessage(true, response.BotResponse));
        }
    }

    // Keyword-based response matching (placeholder for Phase 6 ONNX implementation)
    private static string GetBotResponse(string input) => input switch
    {
        _ when ContainsAny(input, "recommend", "suggest", "best", "which") =>
            "Based on your interest, I'd recommend starting with a consultation. Our top treatments include:<br><br>• <strong>Botox/Dysport</strong> for wrinkles<br>• <strong>HydraFacial</strong> for skin glow<br>• <strong>Hormone Therapy</strong> for energy and vitality",
        _ when ContainsAny(input, "book", "appointment", "schedule") =>
            "You can book online at any of our 3 locations! Visit the <a href='#booking' class='text-brand-teal underline'>booking section</a> or call your preferred clinic directly.",
        _ when ContainsAny(input, "price", "cost", "how much") =>
            "Our treatments range from $49 for biohacking services to $449+ for dermal fillers. Many consultations are complimentary. Would you like pricing for a specific treatment?",
        _ when ContainsAny(input, "location", "where", "address", "hour") =>
            "We have 3 locations in BC: <strong>Langley</strong>, <strong>Victoria</strong>, and <strong>Kelowna</strong>. All clinics are open Mon-Fri 9-5, with Saturday hours varying by location.",
        _ when ContainsAny(input, "skin", "botox", "filler", "facial", "laser") =>
            "Our Skin Rejuvenation treatments include Botox ($299+), fillers ($449+), HydraFacial ($199+), laser treatments ($249+), and medical peels ($349+). Would you like to book a skin consultation?",
        _ when ContainsAny(input, "hormone", "testosterone", "menopause") =>
            "Our Hormone Balancing programs include bioidentical hormone therapy, testosterone optimization, and menopause support. All initial consultations are complimentary!",
        _ when ContainsAny(input, "biohack", "nad", "iv", "peptide", "hbot") =>
            "Our Biohacking services include IV therapy, HBOT, red light therapy, infrared sauna, and neurofeedback. Prices start from $49 CAD. Availability varies by location.",
        _ when ContainsAny(input, "weight", "metabol", "diet") =>
            "Our Healthy Weight program is physician-supervised with free initial consultation. It includes GLP-1 protocols, metabolic testing ($149), and body composition analysis ($99).",
        _ => "I'm here to help with treatment recommendations, booking, pricing, and location info. What would you like to know more about?"
    };

    private static bool ContainsAny(string input, params string[] keywords) =>
        keywords.Any(input.Contains);

    private record ChatMessage(bool IsBot, string Text);
}
