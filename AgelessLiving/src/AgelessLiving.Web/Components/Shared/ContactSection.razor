<SectionHeader Tag="Get in touch" Heading="We'd love to hear from you." />

<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <!-- Left: Form -->
    <form class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input
                type="text"
                placeholder="First name"
                class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition" />
            <input
                type="text"
                placeholder="Last name"
                class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition" />
        </div>

        <input
            type="email"
            placeholder="Email address"
            class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition" />

        <input
            type="tel"
            placeholder="Phone (optional)"
            class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition" />

        <select class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition text-brand-muted">
            <option value="">Select location</option>
            <option value="langley">Langley</option>
            <option value="victoria">Victoria</option>
            <option value="kelowna">Kelowna</option>
        </select>

        <select class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition text-brand-muted">
            <option value="">What are you interested in?</option>
            <option value="skin">Skin Rejuvenation</option>
            <option value="hormone">Hormone Balancing</option>
            <option value="bio">Biohacking</option>
            <option value="weight">Healthy Weight</option>
            <option value="general">General Inquiry</option>
        </select>

        <textarea
            placeholder="Your message"
            rows="4"
            class="w-full px-4 py-3 border border-brand-border rounded-lg text-[14px] bg-white focus:border-brand-teal outline-none transition resize-none"></textarea>

        <button type="submit" class="w-full bg-brand-teal text-white py-3.5 rounded-lg text-[14px] font-medium hover:bg-brand-teal-dark transition">
            Send message
        </button>
    </form>

    <!-- Right: Contact Cards -->
    <div class="space-y-5">
        <!-- Direct Contact Card -->
        <div class="bg-brand-teal-light rounded-lg p-7">
            <h3 class="font-display text-[20px] font-medium mb-5">Direct contact</h3>

            <div class="space-y-4">
                <div>
                    <p class="font-medium text-[14px] mb-1">Langley</p>
                    <p class="text-[13px] text-brand-muted">+1 (236) 326-6830</p>
                    <a href="mailto:langley@agelessliving.ca" class="text-[13px] text-brand-teal">langley@agelessliving.ca</a>
                </div>

                <div>
                    <p class="font-medium text-[14px] mb-1">Victoria</p>
                    <p class="text-[13px] text-brand-muted">+1 (250) 590-5787</p>
                    <a href="mailto:wellness@agelessliving.ca" class="text-[13px] text-brand-teal">wellness@agelessliving.ca</a>
                </div>

                <div>
                    <p class="font-medium text-[14px] mb-1">Kelowna</p>
                    <p class="text-[13px] text-brand-muted">+1 (778) 760-9827</p>
                    <a href="mailto:kelowna@agelessliving.ca" class="text-[13px] text-brand-teal">kelowna@agelessliving.ca</a>
                </div>
            </div>
        </div>

        <!-- Follow Us Card -->
        <div class="bg-brand-gold-light rounded-lg p-7">
            <h3 class="font-display text-[20px] font-medium mb-4">Follow us</h3>
            <div class="flex gap-4">
                <a href="#" class="text-[14px] text-brand-teal font-medium hover:underline">Instagram</a>
                <a href="#" class="text-[14px] text-brand-teal font-medium hover:underline">Facebook</a>
                <a href="#" class="text-[14px] text-brand-teal font-medium hover:underline">YouTube</a>
            </div>
        </div>
    </div>
</div>
