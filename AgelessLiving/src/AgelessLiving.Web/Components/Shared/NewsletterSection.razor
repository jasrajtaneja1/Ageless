<section class="py-20 px-6 lg:px-12 bg-brand-teal-dark text-center">
    <h2 class="font-display text-[34px] font-normal text-white mb-2">Stay in the loop.</h2>
    <p class="text-[15px] text-white/70 mb-8">Sign up for wellness tips, exclusive offers, and updates from our medical team.</p>

    <form class="flex gap-3 justify-center max-w-[500px] mx-auto flex-wrap">
        <input
            type="email"
            placeholder="Enter your email"
            class="flex-1 min-w-[200px] px-5 py-3.5 rounded-md border border-white/20 bg-white/10 text-white text-[14px] placeholder:text-white/50 focus:border-white/50 outline-none" />
        <button type="submit" class="bg-brand-gold text-brand-dark px-7 py-3.5 rounded-md text-[14px] font-medium hover:opacity-90 transition">
            Subscribe
        </button>
    </form>
</section>
