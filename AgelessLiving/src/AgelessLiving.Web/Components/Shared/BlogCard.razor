@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Category { get; set; } = "";
    [Parameter] public string Excerpt { get; set; } = "";
    [Parameter] public string Date { get; set; } = "";
    [Parameter] public string BgColor { get; set; } = "cat-skin";
}

<a href="#" class="bg-white rounded-lg border border-brand-border overflow-hidden hover:border-brand-teal hover:-translate-y-0.5 transition-all block">
    <div class="h-[180px] flex items-center justify-center text-[14px] font-medium text-white bg-@BgColor">
        Photo
    </div>
    <div class="p-6">
        <p class="text-[11px] text-brand-teal font-medium uppercase tracking-[.5px] mb-2">@Category</p>
        <h3 class="font-display text-[19px] font-medium leading-[1.3] mb-2">@Title</h3>
        <p class="text-[13px] text-brand-muted leading-[1.55] mb-3.5">@Excerpt</p>
        <p class="text-[11px] text-brand-light-muted">@Date</p>
    </div>
</a>
